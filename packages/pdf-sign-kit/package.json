  },
  "main": "dist/pdf-sign-kit.cjs.js",
  "module": "dist/pdf-sign-kit.es.js",
  "types": "dist/types/index.d.ts",
  "files": [
    "dist"
  ],
  "style": "dist/styles/index.css",
  "exports": {
    ".": {
      "import": "./dist/pdf-sign-kit.es.js",
      "require": "./dist/pdf-sign-kit.cjs.js"
    },
    "./webcomponents": "./dist/pdf-sign-kit.wc.iife.js",
    "./styles.css": "./dist/styles/index.css"
  },
  "scripts": {
    "build:types": "tsc -p tsconfig.json",
    "build:lib": "vite build --config vite.lib.config.ts",
    "build:wc": "vite build --config vite.wc.config.ts",
    "build:copy-styles": "node scripts/copy-styles.js",
    "build": "npm run build:types && npm run build:lib && npm run build:wc && npm run build:copy-styles",
    "test": "vitest"
  },
  "peerDependencies": {
    "vue": "^3.2"
  },
  "devDependencies": {
    "vite": "^5.0.0",
    "@vitejs/plugin-vue": "^4.0.0",
    "typescript": "^5.0.0",
    "vitest": "^1.0.0",
    "vue": "^3.2"
  },
  "dependencies": {
    "pdf-lib": "^1.17.1"
  }
}
