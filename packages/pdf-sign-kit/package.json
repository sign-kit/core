{
  "name": "@signkit/core",
  "version": "0.0.0",
  "description": "Client-first Vue 3 toolkit for building PDF form templates and collecting signatures in the browser — no backend required.",
  "keywords": [
    "pdf",
    "signature",
    "pdf-signing",
    "form-builder",
    "vue",
    "vue3",
    "web-components",
    "esign",
    "pdf-lib"
  ],
  "homepage": "https://docs.signkit.dev/",
  "bugs": {
    "url": "https://github.com/sign-kit/core/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sign-kit/core.git"
  },
  "license": "Apache-2.0",
  "author": "Marcello Bachechi (https://github.com/pilotkid)",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/pdf-sign-kit.es.js",
      "require": "./dist/pdf-sign-kit.cjs.js"
    },
    "./webcomponents": "./dist/pdf-sign-kit.wc.iife.js",
    "./styles.css": "./dist/styles/index.css"
  },
  "main": "dist/pdf-sign-kit.cjs.js",
  "types": "dist/index.d.ts",
  "directories": {
    "test": "test"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build:types": "node -e \"try{require('fs').rmSync('tsconfig.tsbuildinfo')}catch(_){}\" && vue-tsc -p tsconfig.json",
    "build:lib": "vite build --config vite.lib.config.ts",
    "build:wc": "vite build --config vite.wc.config.ts",
    "build:copy-styles": "node scripts/copy-styles.js",
    "build": "npm run build:types && npm run build:lib && npm run build:wc && npm run build:copy-styles",
    "test": "vitest"
  },
  "dependencies": {
    "pdf-lib": "^1.17.1"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^4.0.0",
    "typescript": "^5.0.0",
    "vite": "^5.0.0",
    "vitest": "^1.0.0",
    "vue": "^3.2",
    "vue-tsc": "^3.2.7"
  },
  "peerDependencies": {
    "vue": "^3.2"
  },
  "sponsor": {
    "url": "https://ko-fi.com/P5P22RTZ6"
  },
  "module": "dist/pdf-sign-kit.es.js",
  "style": "dist/styles/index.css"
}
