# .gitignore for packages/docs

# Node modules
node_modules/

# Vite & VitePress output
.vite/
.vitepress/dist/
.vitepress/.cache/
.vitepress/cache/
dist/

# TypeDoc generated API (optional — remove if you commit generated API)
api/

# Local env files
.env
.env.*.local
.local

# Logs
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*

# OS
.DS_Store
Thumbs.db
ehthumbs.db

# Editor directories
.vscode/
.idea/
*.sublime-workspace
