{
  "name": "pdf-sign-kit-monorepo",
  "private": true,
  "version": "0.0.0",
  "license": "Apache-2.0",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "bootstrap": "npm install",
    "build": "npm run build --workspaces",
    "build:demo": "npm --workspace=demo run build",
    "docs:gen": "typedoc --options typedoc.json",
    "build:docs": "npm run docs:gen && npm --workspace=docs run docs:build",
    "dev:demo": "npm --workspace=demo run dev",
    "dev:docs": "npm --workspace=docs run docs:dev",
    "test": "npm run test --workspaces",
    "test:e2e": "npm --workspace=@sign-kit/core run build:wc && npx playwright test",
    "test:e2e:headed": "npm --workspace=@sign-kit/core run build:wc && npx playwright test --headed",
    "test:e2e:ui": "npx playwright test --ui",
    "test:e2e:skip-build": "npx playwright test",
    "test:artifacts": "npx playwright test tests/e2e/artifact-smoke.spec.ts",
    "validate:build": "node scripts/validate-build.mjs",
    "validate:build:skip-build": "node scripts/validate-build.mjs --skip-build",
    "lint": "npm run lint --workspaces",
    "format": "prettier --write ."
  },
  "dependencies": {
    "@sign-kit/core": "^0.1.0",
    "pdfjs-dist": "^5.6.205",
    "puppeteer": "^24.42.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.44.0",
    "typedoc": "^0.28.19",
    "typedoc-plugin-markdown": "^4.11.0"
  }
}
