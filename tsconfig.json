{
    "compilerOptions": {
        "target": "ES2020",
        "module": "ESNext",
        "moduleResolution": "bundler",
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "baseUrl": ".",
        "paths": {
            "@pdf-sign-kit/*": [
                "packages/*/src"
            ]
        }
    },
    "include": [
        "packages/**/*",
        "demo/**/*",
        "packages/docs/**/*"
    ]
}